{
  "name": "tbh-meter",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "sync-data": "node scripts/sync-data.mjs",
    "predev": "node scripts/sync-data.mjs",
    "prebuild": "node scripts/sync-data.mjs",
    "dev": "electron-vite dev",
    "dev:mock": "node scripts/sync-data.mjs && cross-env TBH_MOCK_API=1 electron-vite dev",
    "build": "electron-vite build",
    "check": "eslint src && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "pretest": "node scripts/sync-data.mjs",
    "test": "vitest run",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:linux": "pnpm build && electron-builder --linux",
    "dist:dir": "pnpm build && electron-builder --dir"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
