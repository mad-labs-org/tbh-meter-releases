{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm check)",
      "Bash(pnpm test)",
      "Bash(ruff check *)",
      "Bash(python3 -m pytest *)",
      "Bash(sh .claude/hooks/test-guards.sh)",
      "mcp__claude-in-chrome__tabs_context_mcp"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-force-push.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-generated-files.sh"
          }
        ]
      }
    ]
  }
}
